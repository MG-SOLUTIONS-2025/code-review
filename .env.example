# === Git Platform ===
GIT_PLATFORM=gitlab                    # "gitlab" or "gitea"
GIT_BASE_URL=https://gitlab.example.com
GIT_TOKEN=glpat-xxxxxxxxxxxx
# GitLab: "api" scope, Reporter role (read MRs, post comments, no merge)
# Gitea: "repo", "write:issue" scope (read PRs, post comments, no merge)

# === LLM Inference ===
INFERENCE_ENGINE=ollama                # "ollama" or "vllm"
OLLAMA_MODEL=qwen2.5-coder:32b        # or :7b for smaller GPU (<20 GB VRAM)

# vLLM settings (only used when INFERENCE_ENGINE=vllm)
VLLM_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct
VLLM_TENSOR_PARALLEL_SIZE=1           # number of GPUs for tensor parallelism
VLLM_URL=http://vllm:8000

# PR-Agent LLM routing
# Must match your active inference engine:
#   Ollama  → LLM_API_BASE=http://ollama:11434   LLM_MODEL_NAME=ollama/<model>
#   vLLM    → LLM_API_BASE=http://vllm:8000      LLM_MODEL_NAME=openai/<model>
LLM_API_BASE=http://ollama:11434
LLM_MODEL_NAME=ollama/qwen2.5-coder:32b

# === Code Intelligence (optional) ===
ENABLE_TABBY=false
TABBY_URL=                             # set to http://tabby:8080 when enabled

# === DefectDojo ===
DEFECTDOJO_URL=http://defectdojo-web:8081  # internal container URL (port 8081)
DEFECTDOJO_ADMIN_PASSWORD=changeme
DEFECTDOJO_API_TOKEN=                  # generated in DefectDojo UI after first login
DEFECTDOJO_SECRET_KEY=change-this-to-a-random-string  # openssl rand -hex 32
DD_ALLOWED_HOSTS=*                     # restrict to specific hosts in production

# === Grafana ===
GRAFANA_ADMIN_PASSWORD=changeme

# === PR-Agent ===
PR_AGENT_WEBHOOK_SECRET=randomsecret

# === Security ===
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3102

# === Nginx Basic Auth ===
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=changeme

# === AI Review Pipeline ===
GATEWAY_URL=http://api-gateway:8000    # used by CI/CD templates
GATEWAY_API_TOKEN=                     # set to protect /run and /comment endpoints
BOT_USERNAME=                          # git username of review bot (for incremental detection)
REVIEW_CHEAP_MODEL=                    # override cheap model (default: same as OLLAMA_MODEL/VLLM_MODEL)
REVIEW_EXPENSIVE_MODEL=                # override expensive model (default: same as OLLAMA_MODEL/VLLM_MODEL)
REVIEW_BATCH_SIZE=6                    # files processed concurrently per batch
MAX_PATCH_CHARS=8000                   # per-file diff truncation (characters, not tokens)
TOKEN_BUDGET_SUMMARIZE=6000            # input token budget for summarize/classify step
TOKEN_BUDGET_REVIEW=24000              # input token budget for full review step
LLM_CONCURRENCY_LIMIT=6               # max concurrent LLM API calls
GIT_CONCURRENCY_LIMIT=10              # max concurrent git API calls

# === Advanced / Rarely Changed ===
# PROMPTS_DIR=/app/config/prompts      # path to prompt templates inside container
# TIKTOKEN_ENCODING=cl100k_base        # tokenizer encoding (default works for most models)
# PR_AGENT_URL=http://pr-agent:3000    # PR-Agent internal URL

# === CI/CD Integration ===
# These variables are set in your CI/CD platform (GitLab CI vars / GitHub secrets),
# NOT in this .env file:
#   GATEWAY_URL              — URL of the API gateway (use internal docker URL or external)
#   GATEWAY_API_TOKEN        — bearer token for authenticating CI calls
#   DEFECTDOJO_URL           — URL of DefectDojo (for upload scripts)
#   DEFECTDOJO_API_TOKEN     — DefectDojo API token
#   DEFECTDOJO_ENGAGEMENT_ID — DefectDojo engagement ID for your project
#   LLM_HOST                 — hostname of LLM service (default: ollama)
#   LLM_PORT                 — port of LLM service (default: 11434)
